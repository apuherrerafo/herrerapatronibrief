{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Servidor H&P Brief",
      "type": "shell",
      "command": "node server.js",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Serving!|Local:"
        }
      },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "group": "build"
    },
    {
      "label": "Abrir H&P en navegador",
      "type": "shell",
      "command": "open",
      "args": ["http://localhost:8081"],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "silent" },
      "group": "build"
    },
    {
      "label": "Subir a GitHub",
      "type": "shell",
      "command": "bash",
      "args": ["-c", "git add . && git commit -m 'update' && git push"],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "group": "build"
    }
  ]
}
